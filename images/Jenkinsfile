pipeline {
    agent any
//  parameters {
//   credentials credentialType: 'com.cloudbees.jenkins.plugins.awscredentials.AWSCredentialsImpl', defaultValue: 'AWS_CREDS_AUTOMATION_ACCT', name: 'AWS_AUTOMATION_ACCOUNT_CRED', required: false
// }

    environment {
        PATH = "${PATH}:${getTerraformPath()}"
        AMI_ID="stack-ami-${BUILD_NUMBER}"
        VERSION = "1.0.${BUILD_NUMBER}"
        RUNNER = "OLUWOLE"
    }
    stages{

         stage('Initial Stage') {
              steps {
                script {
                def userInput = input(id: 'confirm', message: 'Start Pipeline?', parameters: [ [$class: 'BooleanParameterDefinition', defaultValue: false, description: 'Start Pipeline', name: 'confirm'] ])
             }
           }
        }
        

        stage('Terraform init'){
             steps {
                 slackSend (color: '#FFFF00', message: "STARTING TERRAFORM DEPLOYMENT by '${env.RUNNER}': Job '${env.JOB_NAME} [${env.BUILD_NUMBER}]' (${env.BUILD_URL})")
                 sh """
                 cd instances
                 terraform init -upgrade 
                 """                  
         }
         }

        stage('Terraform Plan'){
             steps {
                 sh """
                 cd instances
                 terraform plan -out=tfplan -input=false
                 """                          
         }
         }

        stage('Deploy Infrastructure'){
             steps {
                 slackSend (color: '#FFFF00', message: "STARTING INFRASTRUCTURE BUILD by '${env.RUNNER}': Job '${env.JOB_NAME} [${env.BUILD_NUMBER}]' (${env.BUILD_URL})")
                 sh """
                 cd instances
                 terraform apply -auto-approve
                 """                          
         }
         }



        stage('Configure VPC Peering Route') {
            steps {
              slackSend (color: '#FFFF00', message: "CONFIGURING VPC PEERING ROUTE by '${env.RUNNER}': Job '${env.JOB_NAME} [${env.BUILD_NUMBER}]' (${env.BUILD_URL})")
             
                sh '''
                  PCX=$(aws ec2 describe-vpc-peering-connections \
                    --filters "Name=status-code,Values=active" \
                              "Name=requester-vpc-info.vpc-id,Values=vpc-0e53e3f7331bbeed4" \
                    --query 'VpcPeeringConnections[0].VpcPeeringConnectionId' \
                    --output text --region us-east-2)

                  JENKINS_RTB=$(aws ec2 describe-route-tables \
                    --filters "Name=vpc-id,Values=vpc-0e53e3f7331bbeed4" \
                    --query 'RouteTables[0].RouteTableId' \
                    --output text --region us-east-2)

                  EXISTING=$(aws ec2 describe-route-tables \
                    --route-table-ids $JENKINS_RTB \
                    --query 'RouteTables[0].Routes[?DestinationCidrBlock==`10.0.0.0/16` && State==`active`].DestinationCidrBlock' \
                    --output text --region us-east-2)

                  if [ -z "$EXISTING" ]; then
                    # Delete stale/blackhole route if it exists before creating new one
                    aws ec2 delete-route \
                        --route-table-id $JENKINS_RTB \
                        --destination-cidr-block 10.0.0.0/16 \
                        --region us-east-2 2>/dev/null || true

                    aws ec2 create-route \
                      --route-table-id $JENKINS_RTB \
                      --destination-cidr-block 10.0.0.0/16 \
                      --vpc-peering-connection-id $PCX \
                      --region us-east-2
                    echo "Route created successfully"
                  else
                    echo "Route already exists, skipping"
                  fi
                '''
            }
        }


        stage ('Restore CliXX Database') {
            steps {
             slackSend (color: '#FFFF00', message: "RESTORING CLIXXRETAIL DATABASE by '${env.RUNNER}': Job '${env.JOB_NAME} [${env.BUILD_NUMBER}]' (${env.BUILD_URL})")
             
              sh '''

                #Declare variables for the database restore
                RDS_SG=$(cd instances && terraform output -raw rds_sg_id)
                DB_SUBNET=$(cd instances && terraform output -raw db_subnet_group_name)

                python3 -m venv python3-virtualenv
                source python3-virtualenv/bin/activate

                python3 -m pip install --upgrade pip

                pip install boto3 botocore ansible

                # Install required Ansible collection
                ansible-galaxy collection install amazon.aws --force

                # Ensure Ansible can find collections
                #export ANSIBLE_COLLECTIONS_PATHS=~/.ansible/collections:/usr/share/ansible/collections


                # Run playbook
                ansible-playbook $WORKSPACE/deploy_db_ansible/deploy_db.yml \
                --extra-vars "security_group_id=$RDS_SG db_subnet_group=$DB_SUBNET"

                deactivate


              '''
            }
        }
        stage('Wait For RDS To Be Ready') {
            steps {
              slackSend (color: '#FFFF00', message: "WAITING FOR DATABASE TO COME UP!! by '${env.RUNNER}': Job '${env.JOB_NAME} [${env.BUILD_NUMBER}]' (${env.BUILD_URL})")
             
                sh '''
                    echo "Waiting for RDS to accept connections..."
                    aws rds wait db-instance-available \
                        --db-instance-identifier clixx-retaildb-restore \
                        --region us-east-2
                    echo "RDS is ready!"
                '''
            }
        }



        stage ('Configure RDS Database') {
            steps {
             slackSend (color: '#FFFF00', message: "CONFIGURING CLIXXRETAIL DATABASE by '${env.RUNNER}': Job '${env.JOB_NAME} [${env.BUILD_NUMBER}]' (${env.BUILD_URL})")
             
              withCredentials([string(credentialsId: 'DB_USER_NAME', variable: 'DB_USER_NAME'), string(credentialsId: 'DB_PASSWORD', variable: 'DB_PASSWORD'), string(credentialsId: 'DB_NAME', variable: 'DB_NAME'), string(credentialsId: 'RDS_ENDPOINT', variable: 'RDS_ENDPOINT')]){
              sh '''
               USERNAME=${DB_USER_NAME}
               PASSWORD=${DB_PASSWORD}
               DBNAME=${DB_NAME}
               SERVER_IP=$(curl -s http://checkip.dyndns.org | sed -e 's/.*Current IP Address: //' -e 's/<.*$//')
               #LOAD_BALANCER=$(cd instances && terraform output -raw lb_endpoint)
               RDS_ENDPOINT=${RDS_ENDPOINT}

               echo "use $DBNAME;" > $WORKSPACE/db.setup
               echo "UPDATE wp_options SET option_value = 'http://$SERVER_IP' WHERE option_value LIKE 'http%';">> $WORKSPACE/db.setup
               mysql -u $USERNAME --password=$PASSWORD -h $RDS_ENDPOINT  -D  $DBNAME < $WORKSPACE/db.setup


              '''
              }
          }
        }



           
        // Wait for Inspector2 to scan
        stage('Wait for Inspector Scan') {
            steps {
                slackSend (color: '#FFFF00', message: "WAITING FOR INSPECTOR TO SCAN by '${env.RUNNER}': Job '${env.JOB_NAME} [${env.BUILD_NUMBER}]' (${env.BUILD_URL})")
                sh """
                echo "Waiting for Inspector2 scan to complete..."
                sleep 120
                """
            }
        }

           

        // Proper vulnerability report (Inspector2)
        stage('Build Vulnerability Report') {
            steps {
                sh """
                echo "Fetching Inspector2 findings..."

                aws inspector2 list-findings \
                  --region us-east-1 \
                  --query 'findings[].{Severity:severity, Title:title, Resource:resources[0].id}' \
                  --output table > findings.txt

                cat findings.txt
                """
                slackSend (color: '#FFFF00', message: "VULNERABILTY REPORT COMPLETED by '${env.RUNNER}': Job '${env.JOB_NAME} [${env.BUILD_NUMBER}]' (${env.BUILD_URL})")
            }
        }




              
 def getTerraformPath(){
        def tfHome= tool name: 'terraform-14', type: 'terraform'
        return tfHome
    }
